---
import type { Language } from '../utils/i18n';
import { getHtmlPages } from '../utils/html-pages';

interface Props {
  lang: Extract<Language, 'en' | 'zh'>;
}

const { lang } = Astro.props;
const pages = getHtmlPages(lang);

if (pages.length === 0) {
  return null;
}

const content = {
  en: {
    title: 'HTML Showcase',
    subtitle: 'Standalone HTML pages that can be rendered directly inside the blog.',
    openLabel: 'Open HTML page',
    badge: 'Single-page HTML',
    hrefPrefix: '/blog/html',
  },
  zh: {
    title: 'HTML 展示区',
    subtitle: '可直接在博客中渲染和展示的独立 HTML 单页。',
    openLabel: '打开 HTML 页面',
    badge: 'HTML 单页',
    hrefPrefix: '/cn/blog/html',
  },
} as const;

const currentContent = content[lang];
---

<section class="mb-12">
  <div class="mb-6">
    <div class="inline-flex items-center rounded-full bg-amber-100 px-3 py-1 text-sm font-semibold text-amber-800 dark:bg-amber-900/40 dark:text-amber-200">
      {currentContent.badge}
    </div>
    <h2 class="mt-4 text-3xl font-bold text-gray-900 dark:text-white">{currentContent.title}</h2>
    <p class="mt-2 text-base text-gray-600 dark:text-gray-400">{currentContent.subtitle}</p>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    {pages.map((page) => (
      <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition-transform duration-200 hover:-translate-y-1 hover:shadow-lg dark:border-gray-700 dark:bg-gray-800">
        <div class="flex h-full flex-col justify-between gap-4">
          <div>
            <h3 class="text-2xl font-semibold text-gray-900 dark:text-white">{page.title}</h3>
            <p class="mt-3 text-gray-700 dark:text-gray-300">{page.description}</p>
          </div>
          <div>
            <a
              href={`${currentContent.hrefPrefix}/${page.slug}/`}
              class="inline-flex items-center rounded-lg bg-amber-500 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-amber-600 focus:outline-none focus:ring-4 focus:ring-amber-300 dark:focus:ring-amber-900"
            >
              {currentContent.openLabel}
              <svg class="ms-2 h-3.5 w-3.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9" />
              </svg>
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
